{
  "userName": "your-name",
  "role": "Your Role",
  "avatar": "🧑‍💻",
  "port": 3000,
  "accentColor": "#419BFF",
  "language": "en",
  "journey": {
    "historyLimit": 20,
    "excludedProjectNames": ["Workspaces", "Workspace", "observer-sessions"],
    "weekStartDay": 1
  },
  "claude": {
    "modelPriority": ["opus", "sonnet"],
    "cliPath": "claude"
  },
  "claudeMem": {
    "disableReadCache": false,
    "excludedProjects": [],
    "logPruner": {
      "enabled": false,
      "retentionDays": 7
    }
  }
}
